          "name": "Default",
          "snippet": "const Default = () => {\n    const [open, setOpen] = useState(args.open ?? true)\n\n    return (\n        <div className=\"min-h-[300px]\">\n            <Button onClick={() => setOpen(true)}>Open Modal</Button>\n            <Modal\n                title=\"Confirm Delivery\"\n                open={open}\n                onClose={() => { setOpen(false); args.onClose(); }}>\n                <div className=\"space-y-4\">\n                    <p className=\"text-sm text-gray-600 dark:text-gray-400\">This is the content area of the modal. You can place any form elements, text, or buttons here.\n                                  </p>\n                    <div className=\"flex justify-end gap-2\">\n                        <Button variant=\"ghost\" onClick={() => setOpen(false)}>Cancel</Button>\n                        <Button variant=\"primary\" onClick={() => setOpen(false)}>Confirm</Button>\n                    </div>\n                </div>\n            </Modal>\n        </div>\n    );\n};"
        },
        {
          "id": "ui-modal--without-title",
