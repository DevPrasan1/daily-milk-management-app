rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Users: any authenticated user can read profiles (needed for nearby sellers + phone match)
    // Only the owner can write their own profile
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isUser(userId);
    }

    // Sellers: anyone auth can read (for nearby discovery), only seller can write
    match /sellers/{sellerId} {
      allow read: if isAuth();
      allow write: if isUser(sellerId);
    }

    // SellerBuyers members: seller reads/writes; buyer can read their own member doc
    match /sellerBuyers/{sellerId}/members/{buyerId} {
      allow read: if isUser(sellerId) || isUser(buyerId);
      allow write: if isUser(sellerId);
    }

    // SellerPrices: seller writes, any auth user reads (for bill display)
    match /sellerPrices/{sellerId}/prices/{priceId} {
      allow read: if isAuth();
      allow write: if isUser(sellerId);
    }

    // Records: seller writes; buyer reads their own records
    match /records/{sellerId}/entries/{recordId} {
      allow write: if isUser(sellerId);
      allow read: if isUser(sellerId) ||
        (isAuth() && (resource.data.buyerId == request.auth.uid ||
         (exists(/databases/$(database)/documents/sellerBuyers/$(sellerId)/members/$(resource.data.buyerId)) &&
          get(/databases/$(database)/documents/sellerBuyers/$(sellerId)/members/$(resource.data.buyerId)).data.linkedUserId == request.auth.uid)));
    }

    // BuyerSelfRecords: buyer only
    match /buyerSelfRecords/{buyerId}/entries/{recordId} {
      allow read, write: if isUser(buyerId);
    }

    // Payments: seller writes; buyer reads their own payment records
    match /payments/{sellerId}/transactions/{paymentId} {
      allow write: if isUser(sellerId);
      allow read: if isUser(sellerId) ||
        (isAuth() && (resource.data.buyerId == request.auth.uid ||
         (exists(/databases/$(database)/documents/sellerBuyers/$(sellerId)/members/$(resource.data.buyerId)) &&
          get(/databases/$(database)/documents/sellerBuyers/$(sellerId)/members/$(resource.data.buyerId)).data.linkedUserId == request.auth.uid)));
    }

    // Buyers profile: buyer reads/writes own doc
    match /buyers/{buyerId} {
      allow read, write: if isUser(buyerId);
    }

    // Link requests: any auth user can create; only involved parties can read/update
    match /linkRequests/{requestId} {
      allow create: if isAuth();
      allow read, update: if isAuth() && (
        resource.data.sellerId == request.auth.uid ||
        resource.data.buyerId == request.auth.uid
      );
    }

    // Milkbooks: creator has full access, partner has read access, partner can link via phone
    match /milkbooks/{milkbookId} {
      allow read: if isAuth() && (
        resource.data.creatorId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid ||
        (resource.data.phone != null && (
          request.auth.token.phone_number == resource.data.phone ||
          request.auth.token.phone_number == "+91" + resource.data.phone
        ))
      );
      allow create: if isAuth() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.creatorId == request.auth.uid ||
        (resource.data.phone != null &&
         (request.auth.token.phone_number == resource.data.phone ||
          request.auth.token.phone_number == "+91" + resource.data.phone) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['partnerId']) &&
         request.resource.data.partnerId == request.auth.uid)
      );
      allow delete: if isAuth() && resource.data.creatorId == request.auth.uid;

      match /records/{recordId} {
        allow read: if isAuth() && (
          get(/databases/$(database)/documents/milkbooks/$(milkbookId)).data.creatorId == request.auth.uid ||
          get(/databases/$(database)/documents/milkbooks/$(milkbookId)).data.partnerId == request.auth.uid
        );
        allow write: if isAuth() && get(/databases/$(database)/documents/milkbooks/$(milkbookId)).data.creatorId == request.auth.uid;
      }

      match /payments/{paymentId} {
        allow read: if isAuth() && (
          get(/databases/$(database)/documents/milkbooks/$(milkbookId)).data.creatorId == request.auth.uid ||
          get(/databases/$(database)/documents/milkbooks/$(milkbookId)).data.partnerId == request.auth.uid
        );
        allow write: if isAuth() && get(/databases/$(database)/documents/milkbooks/$(milkbookId)).data.creatorId == request.auth.uid;
      }
    }
  }
}
